{
  "extends": [
    "@phanect/configs/ts",
    "astro/tsconfigs/strict"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "lib": [
      "esnext",
      "dom"
    ],
    "types": [
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@components/*": [ "src/components/*" ],
      "@layouts/*": [ "src/layouts/*" ],
      "@assets/*": [ "src/assets/*" ]
    }
  }
}
