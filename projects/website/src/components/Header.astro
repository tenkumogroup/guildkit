---
import { DarkMode, SkipLink } from "accessible-astro-components";
import { Icon } from "astro-icon/components";
import ExternalLink from "@components/ExternalLink.astro";
import Navigation from "../components/Navigation.astro";
---

<header>
  <SkipLink />
  <Navigation>
    <li class="menu-item type-icon animate-rotate">
      <ExternalLink href="https://github.com/guildkit/guildkit" newTabIcon={false}>
        <Icon name="lucide:github" />
        <span class="sr-only">Go to the GitHub page</span>
      </ExternalLink>
    </li>
    <li class="menu-item type-icon animate-rotate">
      <DarkMode>
        <Icon name="lucide:moon" slot="light" />
        <Icon name="lucide:sun" slot="dark" />
      </DarkMode>
    </li>
  </Navigation>
</header>

<style lang="scss" is:global>
  header {
    .type-icon {
      display: block;
      margin-inline: -7px;

      svg {
        inline-size: 30px;
        block-size: 30px;
      }
    }
  }
</style>
